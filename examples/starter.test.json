{
  "name": "Simple Login Test Example",
  "description": "Basic example showing common test scenarios",
  "timeout": 30000,
  "variables": {
    "baseUrl": "https://www.saucedemo.com",
    "username": "standard_user",
    "password": "secret_sauce"
  },
  "tests": [
    {
      "name": "Test 1: Navigate to website",
      "steps": [
        {
          "action": "navigate",
          "url": "${baseUrl}"
        },
        {
          "action": "waitFor",
          "selector": "body",
          "timeout": 5000
        },
        {
          "action": "log",
          "value": "Successfully navigated to ${baseUrl}"
        }
      ]
    },
    {
      "name": "Test 2: Find and click login button",
      "steps": [
        {
          "action": "navigate",
          "url": "${baseUrl}"
        },
        {
          "action": "click",
          "selector": "input[id='login-button']"
        },
        {
          "action": "waitForNavigation",
          "timeout": 5000
        },
        {
          "action": "log",
          "value": "Clicked login button"
        }
      ]
    },
    {
      "name": "Test 3: Fill login form",
      "steps": [
        {
          "action": "navigate",
          "url": "${baseUrl}"
        },
        {
          "action": "fill",
          "selector": "input[id='user-name']",
          "value": "${username}"
        },
        {
          "action": "fill",
          "selector": "input[id='password']",
          "value": "${password}"
        },
        {
          "action": "log",
          "value": "Filled username and password fields"
        },
        {
          "action": "screenshot",
          "name": "filled-form"
        }
      ]
    },
    {
      "name": "Test 4: Submit form and verify success",
      "steps": [
        {
          "action": "navigate",
          "url": "${baseUrl}"
        },
        {
          "action": "fill",
          "selector": "input[id='user-name']",
          "value": "${username}"
        },
        {
          "action": "fill",
          "selector": "input[id='password']",
          "value": "${password}"
        },
        {
          "action": "click",
          "selector": "input[id='login-button']"
        },
        {
          "action": "waitForNavigation",
          "timeout": 10000
        },
        {
          "action": "assertUrl",
          "url": "${baseUrl}/inventory.html",
          "partial": true,
          "timeout": 5000
        },
        {
          "action": "log",
          "value": "Login successful! Navigated to dashboard"
        }
      ]
    },
    {
      "name": "Test 5: Element visibility checks",
      "steps": [
        {
          "action": "navigate",
          "url": "${baseUrl}/inventory.html"
        },
        {
          "action": "assertElementVisible",
          "selector": "span[data-test=\"title\"]",
          "timeout": 5000
        },
        {
          "action": "assertText",
          "selector": "span[data-test=\"title\"]",
          "text": "Products",
          "partial": true
        },
        {
          "action": "log",
          "value": "Inventory page verified"
        }
      ]
    }
  ]
}
